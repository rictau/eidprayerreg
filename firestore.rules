rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /registrations/{registrationId} {
      // Allow anyone to create a registration.
      allow create: if true;
      // Allow anyone to read a specific registration if they have the ID (e.g. for status page).
      allow get: if true;
      // Allow limited listing for the check email feature, but allow admins full list access
      allow list: if request.auth != null || request.query.limit <= 1;
      // Allow unauthenticated update only for specific fields if necessary.
      allow update: if true;
      // Restrict deletion to authenticated admins.
      allow delete: if request.auth != null;
    }
    match /timeslot/{slotId} {
      allow read: if true;
      // Allow anyone to update the registered counts (needed for transactions during registration).
      allow update: if (request.auth != null) || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registered_ikhwan', 'registered_akhwat']));
      allow create, delete: if request.auth != null;
    }
  }
}
